{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ueidesantos.github.io/outbox-saga-lab/contracts/payments/payment-approved.v1.schema.json",
  "title": "PaymentApprovedV1",
  "type": "object",
  "required": [
    "payment_id",
    "order_id",
    "amount",
    "currency",
    "transaction_id",
    "approved_at_utc"
  ],
  "properties": {
    "payment_id": {
      "type": "string"
    },
    "order_id": {
      "type": "string"
    },
    "amount": {
      "type": "number",
      "minimum": 0
    },
    "currency": {
      "type": "string",
      "minLength": 3,
      "maxLength": 3
    },
    "transaction_id": {
      "type": "string"
    },
    "approved_at_utc": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
